{
	"appId": "com.tomfong.simpleqr",
	"appName": "Simple QR",
	"webDir": "www",
	"android": {
		"initialFocus": false
	},
	"plugins": {
		"SplashScreen": {
			"useDialog": false,
			"androidScaleType": "CENTER_CROP",
			"backgroundColor": "#00a5aa",
			"launchAutoHide": false,
			"androidSplashResourceName": "splash",
			"showSpinner": false,
			"splashFullScreen": true,
			"splashImmersive": true,
			"layoutName": "launch_screen"
		},
		"SystemBars": {
			"insetsHandling": "disable",
			"style": "DEFAULT",
			"hidden": false
		}
	},
	"cordova": {
		"preferences": {
			"ScrollEnabled": "false",
			"BackupWebStorage": "none",
			"orientation": "portrait"
		}
	},
	"server": {
		"iosScheme": "ionic"
	},
	"packageClassList": [
		"ContactsPlugin",
		"ScreenBrightnessPlugin",
		"BarcodeScannerPlugin",
		"AppPlugin",
		"CAPCameraPlugin",
		"ClipboardPlugin",
		"DevicePlugin",
		"FilesystemPlugin",
		"HapticsPlugin",
		"KeyboardPlugin",
		"PreferencesPlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin",
		"ToastPlugin",
		"CDVPlugin"
	]
}
